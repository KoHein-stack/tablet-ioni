* text=auto

# Source files (keep LF to avoid cross-platform diffs)
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.scss text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.xml  text eol=lf
*.java text eol=lf
*.kt   text eol=lf
*.gradle text eol=lf
*.properties text eol=lf

# Windows scripts (keep CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
